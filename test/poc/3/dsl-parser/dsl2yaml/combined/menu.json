{
  "window": {
    "title": "File Manager",
    "width": 800,
    "height": 600
  },
  "menubar": [
    {
      "label": "File",
      "items": [
        {
          "label": "Open File",
          "action": "open_file",
          "shortcut": "Ctrl+O",
          "icon": "file-open"
        },
        {
          "label": "Save",
          "action": "save_file",
          "shortcut": "Ctrl+S",
          "icon": "file-save"
        },
        {
          "label": "Save As",
          "action": "save_as_file",
          "shortcut": "Ctrl+Shift+S",
          "icon": "file-save-as"
        },
        {
          "label": "Close",
          "action": "close_file",
          "shortcut": "Ctrl+W",
          "icon": "file-close"
        },
        {
          "separator": true
        },
        {
          "label": "Exit",
          "action": "exit_app",
          "shortcut": "Ctrl+Q",
          "icon": "app-exit"
        }
      ]
    },
    {
      "label": "Edit",
      "items": [
        {
          "label": "Undo",
          "action": "undo",
          "shortcut": "Ctrl+Z",
          "icon": "edit-undo"
        },
        {
          "label": "Redo",
          "action": "redo",
          "shortcut": "Ctrl+Y",
          "icon": "edit-redo"
        },
        {
          "separator": true
        },
        {
          "label": "Cut",
          "action": "cut",
          "shortcut": "Ctrl+X",
          "icon": "edit-cut"
        },
        {
          "label": "Copy",
          "action": "copy",
          "shortcut": "Ctrl+C",
          "icon": "edit-copy"
        },
        {
          "label": "Paste",
          "action": "paste",
          "shortcut": "Ctrl+V",
          "icon": "edit-paste"
        }
      ]
    },
    {
      "label": "View",
      "items": [
        {
          "label": "Show Sidebar",
          "action": "toggle_sidebar",
          "checked": true
        },
        {
          "label": "Show Preview",
          "action": "toggle_preview",
          "checked": true
        }
      ]
    },
    {
      "label": "Tools",
      "items": [
        {
          "label": "List Files",
          "action": "list_files",
          "shortcut": "Ctrl+L",
          "icon": "list"
        },
        {
          "label": "Find Pattern",
          "action": "find_pattern",
          "shortcut": "Ctrl+F",
          "icon": "search"
        },
        {
          "label": "Count Matches",
          "action": "count_matches",
          "shortcut": "Ctrl+M",
          "icon": "numbers"
        }
      ]
    },
    {
      "label": "Help",
      "items": [
        {
          "label": "About",
          "action": "show_about"
        },
        {
          "label": "Help",
          "action": "show_help",
          "shortcut": "F1"
        }
      ]
    }
  ]
}
